<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import com.marksman.view.GameField?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.marksman.controller.GameViewController"
            prefWidth="1060"
            prefHeight="640"
            styleClass="game-root"
            stylesheets="@marksman.css">

    <!-- Игровое поле -->
    <center>
        <GameField fx:id="gameField"/>
    </center>

    <!-- Нижняя панель: кнопки + статус + собственные очки -->
    <bottom>
        <HBox alignment="CENTER" spacing="16">
            <padding>
                <Insets top="8" right="16" bottom="8" left="16"/>
            </padding>

            <!-- Кнопки управления -->
            <Button fx:id="startBtn"
                    text="Готов"
                    onAction="#onStartClick"
                    styleClass="btn-primary"
                    prefWidth="110" prefHeight="36"/>

            <Button fx:id="pauseBtn"
                    text="Пауза"
                    onAction="#onPauseClick"
                    styleClass="btn-secondary"
                    prefWidth="110" prefHeight="36"/>

            <Button fx:id="shotBtn"
                    text="Выстрел"
                    onAction="#onShotClick"
                    styleClass="btn-shot"
                    prefWidth="110" prefHeight="36"/>

            <!-- Разделитель -->
            <Label text="|" opacity="0.3"/>

            <!-- Собственные счётчики -->
            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Очки:"/>
                <Label fx:id="pointValue" text="0" styleClass="stat-value"/>
            </HBox>

            <HBox spacing="6" alignment="CENTER_LEFT">
                <Label text="Выстрелов:"/>
                <Label fx:id="shotValue" text="0" styleClass="stat-value"/>
            </HBox>

            <!-- Статус игры -->
            <Label fx:id="statusLabel"
                   text="Подключение..."
                   styleClass="status-label"
                   maxWidth="300"/>
        </HBox>
    </bottom>

</BorderPane>