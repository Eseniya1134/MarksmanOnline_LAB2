<?xml version="1.0" encoding="UTF-8"?>

<?import com.marksman.view.GameField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
    game.fxml — игровой экран.
    ЛР3: добавлена кнопка «Лидеры» (leaderboardBtn) и кнопка «Закрыть» для таблицы.
-->
<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.marksman.controller.GameViewController"
            style="-fx-background-color: #1a1a2e;">

    <!-- Верхняя панель управления -->
    <top>
        <HBox spacing="10" style="-fx-padding: 8; -fx-background-color: #16213e;">
            <Button fx:id="startBtn"
                    text="Готов"
                    onAction="#onStartClick"
                    style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 90px;"/>
            <Button fx:id="pauseBtn"
                    text="Пауза"
                    onAction="#onPauseClick"
                    style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 90px;"/>
            <Button fx:id="shotBtn"
                    text="Выстрел [Пробел]"
                    onAction="#onShotClick"
                    style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 140px;"/>

            <!-- ЛР3: кнопка таблицы лидеров -->
            <Button fx:id="leaderboardBtn"
                    text="Лидеры"
                    onAction="#onLeaderboardClick"
                    style="-fx-background-color: #9c27b0; -fx-text-fill: white; -fx-font-weight: bold; -fx-min-width: 90px;"/>

            <!-- ЛР3: кнопка закрыть таблицу лидеров (ESC) -->
            <Button text="Закрыть таблицу [ESC]"
                    onAction="#onCloseLeaderboard"
                    style="-fx-background-color: #607d8b; -fx-text-fill: white; -fx-min-width: 160px;"/>

            <Label fx:id="statusLabel"
                   text="Подключение..."
                   style="-fx-text-fill: #aaaaaa; -fx-padding: 5 10;"/>
        </HBox>
    </top>

    <!-- Игровое поле -->
    <center>
        <GameField fx:id="gameField"/>
    </center>

    <!-- Нижняя панель со счётом -->
    <bottom>
        <HBox spacing="20" style="-fx-padding: 6 12; -fx-background-color: #16213e;">
            <Label text="Счёт:" style="-fx-text-fill: #aaaaaa;"/>
            <Label fx:id="pointValue" text="0"
                   style="-fx-text-fill: #4caf50; -fx-font-weight: bold; -fx-font-size: 16px;"/>
            <Label text="Выстрелов:" style="-fx-text-fill: #aaaaaa;"/>
            <Label fx:id="shotValue" text="0"
                   style="-fx-text-fill: #ff9800; -fx-font-weight: bold; -fx-font-size: 16px;"/>
        </HBox>
    </bottom>

</BorderPane>
